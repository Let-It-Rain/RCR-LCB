{
  "dataList": [
    {
      "id": "0",
      "content": "Тіні минулого переслідують,"
    },
    {
      "id": "1",
      "content": "Пам'ять про потьмянілі дні."
    },
    {
      "id": "2",
      "content": "Обпаливши з голови до ніг мене,"
    },
    {
      "id": "3",
      "content": "Стануть лише попелом на руках."
    },
    {
      "id": "4",
      "content": "Невпинно я біжу."
    },
    {
      "id": "5",
      "content": "По тому про що шкодую так"
    },
    {
      "id": "6",
      "content": "Буду ль одного разу я нудьгувати?"
    },
    {
      "id": "7",
      "content": "Я хочу коли-небудь,"
    },
    {
      "id": "8",
      "content": "Подивившись на пройдений шлях,"
    },
    {
      "id": "9",
      "content": "Ні про що не сумувати."
    },
    {
      "id": "10",
      "content": "Скільки б не залишилося мені ще прожити,"
    },
    {
      "id": "11",
      "content": "Вперед йти доведеться мені."
    },
    {
      "id": "12",
      "content": "Як свічка, в один день згорю дотла,"
    },
    {
      "id": "13",
      "content": "Слідом зникнувши назавжди."
    },
    {
      "id": "14",
      "content": "Закрутившись у вихорі днів,"
    },
    {
      "id": "15",
      "content": "Не можу знайти сил зробити вдих,"
    },
    {
      "id": "16",
      "content": "Але відшукаю дорогу я."
    },
    {
      "id": "17",
      "content": "І хочу коли-небудь,"
    },
    {
      "id": "18",
      "content": "Подивившись на пройдений шлях,"
    },
    {
      "id": "19",
      "content": "Ні про що не сумувати."
    },
    {
      "id": "20",
      "content": "Дай мені, дай мені долетіти до зірки,"
    },
    {
      "id": "21",
      "content": "Розпустити свої крила птахом в небесах нічних."
    },
    {
      "id": "22",
      "content": "І ніч, і ніч неминуче прийде знову, але я"
    },
    {
      "id": "23",
      "content": "Все одно жити далі зможу"
    },
    {
      "id": "24",
      "content": "Продовжувати."
    },
    {
      "id": "25",
      "content": "Навіть у найтемнішу ніч зірка сліпуче сяяла!"
    },
    {
      "id": "26",
      "content": "Погляньте, он там, далеко! Давайте вирушимо якомога швидше - до тієї далекої зірки!"
    },
    {
      "id": "27",
      "content": "Коль ця мрія не закінчена, то...!"
    },
    {
      "id": "28",
      "content": "То..."
    },
    {
      "id": "29",
      "content": "Чи не перейти нам до наступної пісні цього епосу?!"
    }
  ]
}