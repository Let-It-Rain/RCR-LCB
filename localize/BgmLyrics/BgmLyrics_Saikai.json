{
  "dataList": [
    {
      "id": 0,
      "content": "В младой, мой\nмир пустой,"
    },
    {
      "id": 1,
      "content": "Ты пришла, открыв\nдвери замок,"
    },
    {
      "id": 2,
      "content": "Расплёлся лепесток"
    },
    {
      "id": 3,
      "content": "Алым\nКавара-Надэщико."
    },
    {
      "id": 4,
      "content": "Мне явила ты                              \n\nЧто думать я,                                \n\nВсё ещё способна и о других."
    },
    {
      "id": 5,
      "content": "И что храню невинность души\nвнутри"
    },
    {
      "id": 6,
      "content": "Теперь я знаю, -"
    },
    {
      "id": 7,
      "content": "Прошлое -\nне только боль,"
    },
    {
      "id": 8,
      "content": "Неудач\nтьму надо\nОдолеть порой."
    },
    {
      "id": 9,
      "content": "Не кажется жизнь плохой"
    },
    {
      "id": 10,
      "content": "Когда со мной ты!"
    },
    {
      "id": 11,
      "content": "Ценим всё\nпока живём,"
    },
    {
      "id": 12,
      "content": "И S не станет\nSayonara!"
    },
    {
      "id": 13,
      "content": "Мы вспомним о былом..."
    },
    {
      "id": 14,
      "content": "Я лучше стать\nдолжна"
    },
    {
      "id": 15,
      "content": "Ты достойна мира у ног."
    },
    {
      "id": 16,
      "content": "Желаешь ведь\nвзаправду"
    },
    {
      "id": 17,
      "content": "Свой краткий час\nпровести со мною."
    },
    {
      "id": 18,
      "content": "Обойтись защитой здесь нельзя,"
    },
    {
      "id": 19,
      "content": "Чашу не наполнить благами лишь..."
    },
    {
      "id": 20,
      "content": "...Любовь нужна.\n\"Как быть?\"\nЯ спрошу\nсебя..."
    },
    {
      "id": 21,
      "content": "Что мне знать да про любовь?"
    },
    {
      "id": 22,
      "content": "Как воссоздать то что неведомо,"
    },
    {
      "id": 23,
      "content": "Но знаю что должна...\nтебя взрастить я!"
    },
    {
      "id": 24,
      "content": "Коль питанья\nнедостаёт,"
    },
    {
      "id": 25,
      "content": "Буду поливать\nвсей кровью я своей...\nтебя"
    },
    {
      "id": 26,
      "content": "Теперь я знаю, -"
    },
    {
      "id": 27,
      "content": "Жертвы -\nэто лёгкий путь,"
    },
    {
      "id": 28,
      "content": "Расстоянию\nне изменить отнюдь,"
    },
    {
      "id": 29,
      "content": "Что только добра тебе\nжелаю, верь мне!"
    },
    {
      "id": 30,
      "content": "Не разрубить\nнашу алу нить,"
    },
    {
      "id": 31,
      "content": "И S не станет\nSayonara!"
    },
    {
      "id": 32,
      "content": "Простишь ли вскорь ты меня?"
    }
  ]
}