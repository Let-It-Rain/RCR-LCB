{
  "dataList": [
    {
      "id": "0",
      "content": "... Бля."
    },
    {
      "id": "1",
      "content": "Ну чё э народ, погнали нахуй, ёбаный в роооот."
    },
    {
      "id": "2",
      "content": "Пункт назначения - Россия."
    },
    {
      "id": "3",
      "content": "Дорогой мы шли"
    },
    {
      "id": "4",
      "content": "В забытые дни"
    },
    {
      "id": "5",
      "content": "Запретный плод я"
    },
    {
      "id": "6",
      "content": "У древа тогда\nУкрасть вмиг смогла."
    },
    {
      "id": "7",
      "content": "Я кожу сниму\nИ плоть нежную вкушу."
    },
    {
      "id": "8",
      "content": "Прольётся тёплый гной,"
    },
    {
      "id": "9",
      "content": "И ты обрела облик мой,"
    },
    {
      "id": "10",
      "content": "Что я презираю\nВсей душой."
    },
    {
      "id": "11",
      "content": "Страдай!\nЧтобы дальше тихо жить,"
    },
    {
      "id": "12",
      "content": "Чтобы мне тебя простить."
    },
    {
      "id": "13",
      "content": "Если хочешь -\nПродолжай притворяться вновь людьми."
    },
    {
      "id": "14",
      "content": "Замкнём цикл мы.\n(Замкнём цикл мы.)"
    },
    {
      "id": "15",
      "content": "Во мне справедливость,\nЯ знаю, берегут нас\nВсегда мои грехи."
    },
    {
      "id": "16",
      "content": "Страдай!\nПосле смерти ждёт покой,"
    },
    {
      "id": "17",
      "content": "А важна моя ли боль?"
    },
    {
      "id": "18",
      "content": "Коронуем для чего\nМы жестоких с тобой?"
    },
    {
      "id": "19",
      "content": "Мы в этом пекле!\n(Мы в пекле!)"
    },
    {
      "id": "20",
      "content": "Свой город возвели"
    },
    {
      "id": "21",
      "content": "Для себя в аду."
    }
  ]
}