{
  "dataList": [
    {
      "id": "0",
      "content": "Тени прошлого преследуют,"
    },
    {
      "id": "1",
      "content": "Память о потускневших днях."
    },
    {
      "id": "2",
      "content": "Опалив с головы до ног меня,"
    },
    {
      "id": "3",
      "content": "Станут лишь пеплом на руках."
    },
    {
      "id": "4",
      "content": "Безустанно я бегу."
    },
    {
      "id": "5",
      "content": "По тому о чём жалею так"
    },
    {
      "id": "6",
      "content": "Буду ль однажды я скучать?"
    },
    {
      "id": "7",
      "content": "Я хочу когда-нибудь,"
    },
    {
      "id": "8",
      "content": "Посмотрев на пройденный путь,"
    },
    {
      "id": "9",
      "content": "Ни о чём не тосковать."
    },
    {
      "id": "10",
      "content": "Ла ла-ра, ла-ра ла-ра, ла ла-ра, ла-ра, ла-ра"
    },
    {
      "id": "11",
      "content": "Ла ла-ра, ла-ра ла-ра, ла ла-ра, ла-ра, ла-ра"
    },
    {
      "id": "12",
      "content": "Сколько б ни осталось мне ещё прожить,"
    },
    {
      "id": "13",
      "content": "Вперёд идти придётся мне."
    },
    {
      "id": "14",
      "content": "Как свеча, в один день сгорю дотла,"
    },
    {
      "id": "15",
      "content": "Следом исчезнув навсегда."
    },
    {
      "id": "16",
      "content": "Закружившись в вихре дней,"
    },
    {
      "id": "17",
      "content": "Не могу найти сил сделать вдох,"
    },
    {
      "id": "18",
      "content": "Но отыщу дорогу я."
    },
    {
      "id": "19",
      "content": "И хочу когда-нибудь,"
    },
    {
      "id": "20",
      "content": "Посмотрев на пройденный путь,"
    },
    {
      "id": "21",
      "content": "Ни о чём не тосковать."
    },
    {
      "id": "22",
      "content": "Дай мне, дай мне долететь до звезды,"
    },
    {
      "id": "23",
      "content": "Распустить свои крылья птицей в небесах ночных."
    },
    {
      "id": "24",
      "content": "И ночь, и ночь неизбежно придёт вновь, но я"
    },
    {
      "id": "25",
      "content": "Всё равно жить дальше смогу"
    },
    {
      "id": "26",
      "content": "Продолжать."
    },
    {
      "id": "27",
      "content": "В.Р. жить дальше С.П."
    }
  ]
}